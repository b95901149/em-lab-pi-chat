# Copy to .dev.vars for local wrangler dev (gitignored)

# Provider: groq (default) or gemini
LLM_PROVIDER=groq

# Groq — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# 繁中較佳可改: qwen/qwen3-32b

# Gemini (optional) — https://aistudio.google.com/apikey
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash-lite

ALLOWED_ORIGINS=http://127.0.0.1:8769,http://localhost:8769
